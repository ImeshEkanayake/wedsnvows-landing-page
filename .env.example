NODE_ENV=development
PORT=3000

# Set this on Railway if you add a PostgreSQL database service.
# Without DATABASE_URL, submissions are stored in data/submissions.csv.
DATABASE_URL=

# Required for downloading /admin/submissions.csv?token=your-secret-token
ADMIN_TOKEN=change-me-before-deploying

# Leave blank for Railway Postgres. Use PGSSL=true only for providers that require SSL.
PGSSL=
